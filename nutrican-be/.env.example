# NutriCan PT — Backend Environment Configuration
# Copy this file to .env and fill in ALL values.
# WITHOUT .env IN THIS DIRECTORY, THE APP WILL NOT START.

# ===== Database =====
# Full connection URL — REQUIRED
DATASOURCE_URL=jdbc:postgresql://localhost:5432/nutrican_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# ===== MinIO Object Storage =====
# URL — REQUIRED
MINIO_URL=http://localhost:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_NAME=

# ===== Ollama AI Model =====
# URL — REQUIRED
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_MEAL_MODEL=

# ===== ResNet AI Server =====
# URL — REQUIRED
AI_RESNET_URL=http://localhost:8000

# ===== Server =====
SERVER_PORT=8080

# ===== JWT Authentication =====
# REQUIRED — generate a secure random key (min 32 chars)
JWT_SECRET_KEY=
JWT_EXPIRATION_MS=86400000

# ===== CORS =====
# Comma-separated list of allowed frontend origins (no spaces)
# Example: http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=

# ===== Firebase Admin SDK =====
# Path to firebase-service-account.json (relative to nutrican-be/)
FIREBASE_CREDENTIALS_PATH=
# Set to true to enable Google Sign-In
FIREBASE_ENABLED=

# ===== Email (SMTP) =====
# Password reset + notification emails (hire result, SOS, refund, weekly summary)
# Gmail: host=smtp.gmail.com, port=587, use App Password (not your login password)
# App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ===== Frontend URL =====
# Reset-password links + deep links in notification emails
FRONTEND_URL=

# ===== VNPay (coaching payment) =====
# Sandbox portal: https://sandbox.vnpayment.vn/merchantv2/
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payment/vnpay/return
# Public URL VNPay can call (use ngrok/tunnel in local dev). Also set the same URL in merchant portal.
# Leave empty to rely on portal-configured IPN only.
VNPAY_IPN_URL=

# Third-party service: https://api.idg.vnpt.vn
# Base URL — keep as example; tokens/keys MUST be obtained from VNPT portal
VNPT_EKYC_BASE_URL=https://api.idg.vnpt.vn
VNPT_EKYC_ACCESS_TOKEN=
VNPT_EKYC_TOKEN_ID=
VNPT_EKYC_TOKEN_KEY=
# Redis - Distributed Rate Limiting
REDIS_HOST=
REDIS_PORT=
