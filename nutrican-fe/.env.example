# NutriCan PT — Frontend Environment Configuration
# Copy this file to .env and fill in ALL values.
# WITHOUT .env IN THIS DIRECTORY, THE APP WILL NOT START.

# ===== Firebase Configuration =====
# Obtain these from: Firebase Console > Project Settings > Your Apps > Web App
# API Key — keep blank, must be filled from Firebase Console
VITE_FIREBASE_API_KEY=
# Auth Domain — format: your-project.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=
# Project ID — format: your-project-id
VITE_FIREBASE_PROJECT_ID=
# Storage Bucket — format: your-project.apps.firebasestorage.app
VITE_FIREBASE_STORAGE_BUCKET=
# Messaging Sender ID — numeric string from Firebase Console
VITE_FIREBASE_MESSAGING_SENDER_ID=
# App ID — format: 1:xxx:web:xxx
VITE_FIREBASE_APP_ID=
# Measurement ID (optional, for Analytics) — format: G-XXXXXXXXXX
VITE_FIREBASE_MEASUREMENT_ID=
